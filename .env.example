# ============================================
# Investment Research Dashboard - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- PostgreSQL ---
POSTGRES_USER=ird_user
POSTGRES_PASSWORD=ird_password
POSTGRES_DB=ird_db

# --- JWT Authentication ---
JWT_SECRET=your-secure-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- Embeddings / Vector Search ---
# Jina AI works well as a drop-in embedding provider for FAISS
JINA_API_KEY=your-jina-api-key-here

# Optional Gemini fallback
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- NewsAPI ---
# Get your key at: https://newsapi.org/register
NEWS_API_KEY=your-newsapi-key-here

# --- Financial Modeling Prep ---
# Get your key at: https://financialmodelingprep.com/developer
FMP_API_KEY=your-fmp-api-key-here

# --- Groq ---
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# --- Frontend ---
# For EC2: set to http://<EC2-PUBLIC-IP>/api  OR  https://yourdomain.com/api
# NOTE: NEXT_PUBLIC_API_URL is baked into the frontend image at build time.
# Rebuild the frontend image after changing this value.
NEXT_PUBLIC_API_URL=http://YOUR_EC2_IP_OR_DOMAIN/api
